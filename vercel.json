{
    "routes": [{
            "src": "^/flycer/?$",
            "dest": "/api/gateway"
        },
        {
            "src": "^/$",
            "dest": "/api/gateway"
        },
        {
            "src": "^/api/(.*)$",
            "status": 404
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "^/(.*)$",
            "dest": "/api/gateway"
        }
    ]
}
