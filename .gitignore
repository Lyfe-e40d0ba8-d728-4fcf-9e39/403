# ═══════════════════════════════════════════════════════
#  NODE.JS + VERCEL PROJECT (.gitignore FINAL FIX)
# ═══════════════════════════════════════════════════════

# ── Logs ───────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Diagnostic reports ────────────────────────────────
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Runtime data ───────────────────────────────────────
pids
*.pid
*.seed
*.pid.lock

# ── Coverage ───────────────────────────────────────────
lib-cov
coverage
*.lcov
.nyc_output

# ── Build / cache ──────────────────────────────────────
.cache
.parcel-cache
.fusebox/
.dynamodb/
.firebase/
.tern-port

# ── Dependencies ───────────────────────────────────────
node_modules/
jspm_packages/
web_modules/
.pnpm-store

# ── TypeScript ─────────────────────────────────────────
*.tsbuildinfo

# ── npm / yarn / pnpm ──────────────────────────────────
.npm
.eslintcache
.stylelintcache
.node_repl_history
*.tgz
.yarn-integrity

# Yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ── Framework outputs ──────────────────────────────────
.next
out
.nuxt
dist
.output
.vuepress/dist
.temp
.svelte-kit/
**/.vitepress/dist
**/.vitepress/cache
.docusaurus

# ── Serverless ─────────────────────────────────────────
.serverless/

# ── Vite ───────────────────────────────────────────────
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

# ── VSCode test ────────────────────────────────────────
.vscode-test

# ── Bower / Grunt / legacy ─────────────────────────────
bower_components
.grunt

# ── Security: ENV FILES (IMPORTANT FIX) ────────────────
.env
.env.local
.env.production
.env.development
.env.test
.env.*.local

# keep example env for repo sharing
!.env.example

# ═══════════════════════════════════════════════════════
# END
